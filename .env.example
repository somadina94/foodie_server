REDIS_URL=redis://127.0.0.1:6379

KITCHEN_MAX_CONCURRENT=
DELIVERY_FEE=

VAPID_SUBJECT=mailto:support@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_CURRENCY=usd

RIDER_ASSIGN_RETRY_MS=
RIDER_ASSIGN_MAX_ATTEMPTS=

B2_ENDPOINT=
B2_BUCKET_ID=
B2_BUCKET_NAME=
B2_APPLICATION_KEY=
B2_APPLICATION_KEY_ID=
B2_BUCKET_REGION=
B2_PUBLIC_FILE_BASE_URL=

