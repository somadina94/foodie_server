NODE_ENV=production
PORT=4800

DATABASE=mongodb+srv://USER:PASSWORD@cluster.example.net/foodie
DATABASE_PASSWORD=

JWT_SECRET=
JWT_EXPIRES_IN=90d

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_ADDRESS=
EMAIL_FROM=
EMAIL_PASSWORD=
EMAIL_TO=
ADMIN_EMAIL=

